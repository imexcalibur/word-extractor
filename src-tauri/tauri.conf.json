{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordExtractor",
  "version": "0.1.0",
  "identifier": "com.ovo.word-extractor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Word文档内容提取工具",
        "width": 1200,
        "height": 700,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}